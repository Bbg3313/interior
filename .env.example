# Supabase (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 관리자 로그인 (아이디/비밀번호)
VITE_ADMIN_ID=admin
VITE_ADMIN_PASSWORD=your-password

# 플로팅 소셜 (비우면 아래 기본 URL 사용)
# 카카오 채널: https://pf.kakao.com/_RwMxan
VITE_KAKAO_CHANNEL_URL=
# 비우면 기본: https://www.instagram.com/soulinwoodwork
VITE_INSTAGRAM_URL=

# --- Storage 옮기기 스크립트 전용 (pnpm run migrate:storage) ---
# 여기에 service_role 을 적지 마세요. 깃에 올라가면 위험합니다.
# PowerShell 예: $env:MIGRATE_OLD_URL="https://....supabase.co" 등 설정 후 같은 창에서 스크립트 실행.
# MIGRATE_OLD_URL / MIGRATE_OLD_SERVICE_ROLE / MIGRATE_NEW_URL / MIGRATE_NEW_SERVICE_ROLE
# 선택: MIGRATE_BUCKET (기본 portfolio-images)
#
# DB 행 통째로 옮기기: 새 DB에서 scripts/clear-new-db-for-migrate.sql 실행 후
#   pnpm run migrate:db
